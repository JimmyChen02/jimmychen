# GitHub Personal Access Token (optional — increases rate limit from 60 to 5000 req/hr)
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only is fine)
GITHUB_TOKEN=ghp_your_token_here

# GitHub username to fetch repos for
NEXT_PUBLIC_GITHUB_USERNAME=JimmyChen02

# Site URL (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL=https://jimmychen.dev
